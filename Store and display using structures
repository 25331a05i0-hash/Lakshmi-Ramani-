#include <stdio.h>
struct Student {
    int id;
    char name[50];
    float marks;
};
int main() {
    struct Student s[3];
    int i;
    for(i = 0; i < 3; i++) {
        printf("\nEnter details of student %d\n", i+1);
        printf("ID: ");
        scanf("%d", &s[i].id);
        printf("Name: ");
        scanf("%s", s[i].name);
        printf("Marks: ");
        scanf("%f", &s[i].marks);
    }
    printf("\nStudent Details:\n");
    for(i = 0; i < 3; i++) {
        printf("\nID: %d\nName: %s\nMarks: %.2f\n",
               s[i].id, s[i].name, s[i].marks);
    }
