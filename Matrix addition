#include<stdio.h>
int main(){
int a[10][10],b[10][10],sum[10][10];
int i,j,p,q;
	printf("enter the number of rows;");
	scanf("%d",&p);
	printf("enter the number of columns:");
	scanf("%d",&q);
	printf("\nenter the elements of first matrix:\n");
	for(int i=0;i<p;i++){
	for(int j=0;j<q;j++){
	scanf("%d",&a[i][j]);
	}
}
	printf("\nenter the elements of second matrix:\n");
	for(int i=0;i<p;i++){
	for(int j=0;j<p;j++){
	scanf("%d",&b[i][j]);
	}
}
for(int i=0;i<p;i++){
for(int j=0;j<q;j++){
sum[i][j]=a[i][j]+b[i][j];
}
}	printf("\nsum of matrices:\n");
	for(int i=0;i<p;i++){
	for(int j=0;j<q;j++){
	printf("%d\t",sum[i][j]);
}
printf("\n");
}
return 0;
}

